# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit secrets.

# Supabase project endpoint and publishable / anon key.
# Found under Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# TMDB API v3 key. Used server-side by /api/search?category=film for
# film autocomplete and metadata. Request one at
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key

# BoardGameGeek bearer token. Required since late 2025; without it,
# /api/search?category=braetspil returns HTTP 401 and the person page
# shows a Danish-language error banner. Manual board-game adds still
# work without a token. Apply for one by registering the app at
# https://boardgamegeek.com/using_the_xml_api
BGG_API_TOKEN=your-bgg-api-token

# Unsplash API access key. Used server-side by /api/image-search for
# the image picker in the manual add flow. Create one at
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Password for the root /admin panel (workspace and person management,
# global streaming platforms). Pick something long and random.
ADMIN_PASSWORD=your-admin-password
